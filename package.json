{
  "name": "streamhub-tv",
  "version": "1.0.0",
  "description": "StreamHub TV — Netflix-style IPTV streaming hub for Fire TV",
  "private": true,
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 3000",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0 --port 3000",
    "start": "serve -s dist -l 3000",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "hls.js": "^1.5.7",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@vitejs/plugin-react": "^4.2.1",
    "jsdom": "^28.1.0",
    "serve": "^14.2.1",
    "terser": "^5.46.0",
    "vite": "^5.4.2",
    "vitest": "^4.0.18"
  }
}
